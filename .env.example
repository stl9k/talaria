###
# Domain settings
###

DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

###
# Network
###

INTERNAL_SUBNET=172.20.0.0/16

IP_NGINX=172.20.0.2
IP_3XUI=172.20.0.10
IP_TELEMT=172.20.0.20
IP_MATRIX=172.20.0.30
IP_ELEMENT=172.20.0.31

###
# Ports
###

# 3X-UI
XUI_PORT=2053

# Telemt
TELEMT_PORT=8443

# Matrix
MATRIX_PORT=8008

# Element
ELEMENT_PORT=80

###
# Telemt settings
###

TELEMT_SECRET=changeThisSecretToRandomString32chars 
TELEMT_DOMAIN=${DOMAIN}

###
# 3X-UI settings
###

XUI_USERNAME=admin
XUI_PASSWORD=admin #CHANGE IT!!!
XUI_PANEL_DOMAIN=${DOMAIN}

###
# Matrix settings
###

MATRIX_REGISTRATION_SECRET=generateRandomSecretForMatrix
MATRIX_DB_PASSWORD=secureMatrixDbPassword

# I want my TZ as well...
TZ=Europe/Moscow
